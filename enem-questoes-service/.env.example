# Variáveis de Ambiente — Microsserviço de Questões ENEM

# Porta em que o serviço será executado
PORT=3000

# URL base da API externa ENEM
ENEM_API_BASE_URL=https://api.enem.dev/v1

# Timeout para requisições à API ENEM (em milissegundos)
ENEM_API_TIMEOUT=10000

# Ambiente de execução (development | production)
NODE_ENV=development
